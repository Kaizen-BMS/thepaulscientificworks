
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model InstitutionType {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text

  image       String?    @db.VarChar(500)
  icon        String?    @db.VarChar(500)

  order       Int        @default(0)
  isActive    Boolean    @default(true)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  categories  Category[]

  @@index([slug])
  @@index([isActive])
}

model Category {
  id                Int             @id @default(autoincrement())

  name              String          @db.VarChar(255)
  slug              String          @unique @db.VarChar(255)

  description       String?         @db.Text

  image             String?         @db.VarChar(500)
  icon              String?         @db.VarChar(500)

  order             Int             @default(0)

  isActive          Boolean         @default(true)
  showOnHome        Boolean         @default(false)

  institutionTypeId Int?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  institutionType   InstitutionType? @relation(fields: [institutionTypeId], references: [id], onDelete: SetNull)

  subcategories     SubCategory[]
  products          Product[]

  @@index([slug])
  @@index([institutionTypeId])
  @@index([isActive])
  @@index([showOnHome])
}

model SubCategory {
  id          Int       @id @default(autoincrement())

  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)

  description String?   @db.Text

  image       String?   @db.VarChar(500)

  order       Int       @default(0)

  isActive    Boolean   @default(true)

  categoryId  Int

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  products    Product[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
}

model Product {
  id                Int            @id @default(autoincrement())

  // =========================
  // PRODUCT INFO
  // =========================

  productCode       String         @unique @db.VarChar(100)

  name              String         @db.VarChar(500)

  slug              String         @unique @db.VarChar(500)

  shortDescription  String?        @db.VarChar(1000)

  description       String?        @db.LongText

  specifications    String?        @db.LongText

  // =========================
  // COMMERCIAL
  // =========================

  price             Decimal?       @db.Decimal(10, 2)

  priceOnRequest    Boolean        @default(true)

  // =========================
  // MEDIA
  // =========================

  featuredImage     String?        @db.VarChar(500)

  // =========================
  // FLAGS
  // =========================

  isFeatured        Boolean        @default(false)

  showOnHome        Boolean        @default(false)

  isActive          Boolean        @default(true)

  // =========================
  // SEO
  // =========================

  metaTitle         String?        @db.VarChar(500)

  metaDescription   String?        @db.VarChar(1000)

  // =========================
  // SORTING
  // =========================

  order             Int            @default(0)

  // =========================
  // RELATIONS
  // =========================

  categoryId        Int

  subCategoryId     Int?

  createdAt         DateTime       @default(now())

  updatedAt         DateTime       @updatedAt

  category          Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  subCategory       SubCategory?   @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)

  images            ProductImage[]

  pdfs              ProductPdf[]

  inquiries         Inquiry[]

  // =========================
  // INDEXES
  // =========================

  @@index([slug])

  @@index([productCode])

  @@index([categoryId])

  @@index([subCategoryId])

  @@index([isFeatured])

  @@index([showOnHome])

  @@index([isActive])
}

model ProductImage {
  id          Int       @id @default(autoincrement())

  url         String    @db.VarChar(500)

  alt         String?   @db.VarChar(500)

  order       Int       @default(0)

  productCode   Int

  createdAt   DateTime  @default(now())

  product     Product   @relation(fields: [productCode], references: [id], onDelete: Cascade)

  @@index([productCode])
}

model ProductPdf {
  id          Int       @id @default(autoincrement())

  url         String    @db.VarChar(500)

  title       String?   @db.VarChar(500)

  productCode   Int

  createdAt   DateTime  @default(now())

  product     Product   @relation(fields: [productCode], references: [id], onDelete: Cascade)

  @@index([productCode])
}

model Testimonial {
  id             Int       @id @default(autoincrement())

  quote          String    @db.Text

  authorName     String    @db.VarChar(255)

  authorRole     String?   @db.VarChar(255)

  organization   String?   @db.VarChar(255)

  image          String?   @db.VarChar(500)

  rating         Int       @default(5)

  isActive       Boolean   @default(true)

  showOnHome     Boolean   @default(true)

  order          Int       @default(0)

  createdAt      DateTime  @default(now())

  updatedAt      DateTime  @updatedAt

  @@index([isActive])

  @@index([showOnHome])
}

model Certification {
  id            Int       @id @default(autoincrement())

  name          String    @db.VarChar(255)

  image         String?   @db.VarChar(500)

  issuer        String?   @db.VarChar(255)

  description   String?   @db.Text

  isActive      Boolean   @default(true)

  order         Int       @default(0)

  createdAt     DateTime  @default(now())

  updatedAt     DateTime  @updatedAt

  @@index([isActive])
}

model Blog {
  id              Int       @id @default(autoincrement())

  title           String    @db.VarChar(500)

  slug            String    @unique @db.VarChar(500)

  content         String    @db.LongText

  excerpt         String?   @db.Text

  image           String?   @db.VarChar(500)

  author          String?   @db.VarChar(255)

  isPublished     Boolean   @default(false)

  showOnHome      Boolean   @default(false)

  metaTitle       String?   @db.VarChar(500)

  metaDescription String?   @db.VarChar(1000)

  createdAt       DateTime  @default(now())

  updatedAt       DateTime  @updatedAt

  @@index([slug])

  @@index([isPublished])

  @@index([showOnHome])
}

model Inquiry {
  id              Int       @id @default(autoincrement())

  name            String    @db.VarChar(255)

  email           String    @db.VarChar(255)

  phone           String?   @db.VarChar(50)

  organization    String?   @db.VarChar(255)

  message         String    @db.Text

  productCode       Int?

  productName     String?   @db.VarChar(500)

  status          String    @default("new") @db.VarChar(50)

  isRead          Boolean   @default(false)

  createdAt       DateTime  @default(now())

  updatedAt       DateTime  @updatedAt

  product         Product?  @relation(fields: [productCode], references: [id], onDelete: SetNull)

  @@index([productCode])

  @@index([status])

  @@index([isRead])

  @@index([createdAt])
}

model Setting {
  id          Int       @id @default(autoincrement())

  key         String    @unique @db.VarChar(255)

  value       String?   @db.LongText

  group       String?   @db.VarChar(100)

  createdAt   DateTime  @default(now())

  updatedAt   DateTime  @updatedAt

  @@index([key])

  @@index([group])
}

model HeroSlide {
  id            Int       @id @default(autoincrement())

  title         String    @db.VarChar(500)

  subtitle      String?   @db.VarChar(1000)

  description   String?   @db.Text

  image         String?   @db.VarChar(500)

  buttonText    String?   @db.VarChar(100)

  buttonLink    String?   @db.VarChar(500)

  order         Int       @default(0)

  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())

  updatedAt     DateTime  @updatedAt

  @@index([isActive])
}

model AdminUser {
  id          Int       @id @default(autoincrement())

  name        String    @db.VarChar(255)

  email       String    @unique @db.VarChar(255)

  password    String    @db.VarChar(500)

  role        String    @default("admin") @db.VarChar(50)

  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())

  updatedAt   DateTime  @updatedAt

  @@index([email])
}

